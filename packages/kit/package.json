{
  "name": "@momoyu-ink/kit",
  "version": "0.10.0",
  "description": "Software Development Kit of Moyu Visual Novel Engine",
  "main": "dist/lib.cjs",
  "module": "dist/lib.mjs",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.mjs",
      "require": "./dist/lib.cjs",
      "default": "./dist/lib.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.mjs",
      "require": "./dist/jsx-runtime.cjs",
      "default": "./dist/jsx-runtime.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.mjs",
      "require": "./dist/jsx-dev-runtime.cjs",
      "default": "./dist/jsx-dev-runtime.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "AGENTS.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "prepack": "tsup",
    "build": "tsup",
    "watch": "tsup --watch"
  },
  "author": "Icemic <bingfeng.web@gmail.com>",
  "homepage": "https://momoyu.ink",
  "license": "MPL-2.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@react-spring/animated": "^10.0.3",
    "@react-spring/core": "^10.0.3",
    "@react-spring/rafz": "^10.0.3",
    "@react-spring/shared": "^10.0.3",
    "react-reconciler": "^0.33.0",
    "valtio": "^2.1.7",
    "zod": "^4.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": ">=24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-reconciler": "^0.33.0",
    "react": "^19.2.1",
    "rimraf": "^6.1.2",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
